# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used for magic-link redirects when request Host header is unavailable
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Maps JavaScript API — /canvass/map and shaded ward maps on /wards/[slug]
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-side only — never NEXT_PUBLIC_*
# Required for AJAX Guide (/api/assistant) and admin Co-pilot. On Netlify, add the same name in
# Site settings → Environment variables, then trigger a new deploy.
# OPENAI_API_KEY=
