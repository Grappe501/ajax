# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to true on staging to expose /dev preview tools (dummy admin + demo ward dashboard). Never enable in production.
# NEXT_PUBLIC_DEV_PORTAL=true

# Used for magic-link redirects when request Host header is unavailable
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Maps JavaScript API — /canvass/map and shaded ward maps on /wards/[slug]
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-side only — never NEXT_PUBLIC_*
# Required for AJAX Guide (/api/assistant) and admin Co-pilot. On Netlify, add the same name in
# Site settings → Environment variables, then trigger a new deploy.
# Quick local setup (prompts + verifies against OpenAI): npm run setup:openai
# OPENAI_API_KEY=
# Also powers: POST /api/voice/transcribe (Whisper), /api/voice/cleanup, /api/assistant/agent tools.
# GET /api/assistant/status returns { configured, model } for UI — no secret exposed.

# AJAX Guide read-aloud: ElevenLabs TTS (optional — falls back to browser speech if unset).
# Get your API key from https://elevenlabs.io/ — or run: npm run list-voices:elevenlabs
# ELEVENLABS_API_KEY=
# Campaign default voice for AJAX Guide (set the same in Netlify):
ELEVENLABS_VOICE_ID=6aDn1KB0hjpdcocrUkmq
# Optional — default is eleven_multilingual_v2 (see ElevenLabs docs; e.g. eleven_turbo_v2_5 for lower latency)
# ELEVENLABS_MODEL_ID=
